# -----------------------------------------------------------------------------
# AnyMind Environment Variables Example Template
# Rename or copy this file to '.env' in local development.
# -----------------------------------------------------------------------------

# Next.js Application URL (for local: http://localhost:3000)
NEXT_PUBLIC_URL=http://localhost:3000

# Private key of the developer wallet used for contract deployments on Monad Testnet (Hardhat)
# WARNING: Do not push your real private keys to Github repositories!
PRIVATE_KEY=0x_your_private_key_hex_here

# Apify API Token (required for live Google/Amazon e-commerce scrapers)
APIFY_API_TOKEN=apify_api_your_token_here

# Sarvam AI API Key (required for orchestrator dynamic routing / Sarvam-105B MoE model)
SARVAM_API_KEY=your_sarvam_api_key_here

# OpenAI API Key (optional fallback for orchestrator dynamic planner)
OPENAI_API_KEY=sk-proj-your_openai_key_here
